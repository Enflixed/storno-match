# Server
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/storno_match"

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PLATFORM_ACCOUNT_ID=acct_your_platform_account_id

# Email (Resend or SMTP)
SMTP_HOST=smtp.resend.dev
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=noreply@storno-match.com

# Frontend URL (for callbacks)
FRONTEND_URL=http://localhost:5173
